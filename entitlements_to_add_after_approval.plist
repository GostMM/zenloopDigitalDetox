<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Entitlements à ajouter APRÈS approbation d'Apple -->
    
    <!-- Application Enumeration - Pour lister les apps installées -->
    <key>com.apple.developer.application-enumeration</key>
    <true/>
    
    <!-- LaunchServices Application Enumeration - Accès aux services de lancement -->
    <key>com.apple.private.LaunchServices.ApplicationEnumeration</key>
    <true/>
    
    <!-- Bundle Information Access - Accès aux informations des bundles d'apps -->
    <key>com.apple.private.security.storage.ApplicationBundles</key>
    <true/>
    
    <!-- Application Icon Access - Accès aux icônes d'applications (optionnel) -->
    <key>com.apple.private.ApplicationAccessibilityContainers</key>
    <true/>
    
    <!-- System Information Access - Pour accéder aux métadonnées système (optionnel) -->
    <key>com.apple.private.system-information</key>
    <true/>
</dict>
</plist>